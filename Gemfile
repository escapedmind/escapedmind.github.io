source "https://rubygems.org"

# Ce "gem" permet à GitHub de simuler son environnement de publication
gem "github-pages", group: :jekyll_plugins

# Ce "gem" est nécessaire pour charger le thème à distance
gem "jekyll-remote-theme"

# Plugins recommandés pour Minimal Mistakes
group :jekyll_plugins do
  gem "jekyll-include-cache"
  gem "jekyll-sitemap"
  gem "jekyll-gist"
  gem "jekyll-feed"
end
